LANGCHAIN_PROVIDER=openai
LANGCHAIN_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MAX_ITERATIONS=30
BOCHA_API_KEY=your-bocha-api-key

# --- added in this revision ---
# Filesystem sandbox for read_file / write_file. Leave unset to keep the
# default (cwd + cwd/runs). Set to 1 to restore the legacy unbounded
# behaviour where the agent can roam anywhere.
# LOOP_AGENT_UNRESTRICTED_FILES=

# LLM retry tuning. See README "LLM retries" for semantics.
# MAX_RETRIES=3
# TOKEN_THRESHOLD=40000

# CORS origins for browser clients. Comma-separated list. Defaults to
# localhost / 127.0.0.1 on any port if unset.
# LOOP_AGENT_CORS_ORIGINS=https://app.example.com
